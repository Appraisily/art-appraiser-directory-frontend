{
    "name": "art-appraiser-directory-frontend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "npm run check:static",
        "check:static": "node ./scripts/check-static-site.mjs --public-dir public_site",
        "preview": "node ./scripts/serve-static.js --public-dir public_site",
        "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "test:html": "node ./scripts/test-html.js --public-dir public_site",
        "serve:static": "node ./scripts/serve-static.js --public-dir public_site",
        "count:appraisers": "node ./scripts/count-appraisers.js",
        "build:llm-feeds": "node ./scripts/build-directory-llm-feeds.mjs --public-dir public_site --kind art",
        "env:check": "node ../../env-governance/run-check.mjs --schema frontends/art-appraiser-directory-frontend",
        "publish": "node -e \"console.error('Full generated publish is disabled from npm. Edit profile/location HTML directly and use npm run publish:patch for homepage/nav/footer/assets.'); process.exit(1)\"",
        "publish:patch": "node ./scripts/publish-patch.mjs --public-dir public_site"
    },
    "dependencies": {
        "@radix-ui/react-navigation-menu": "^1.2.5",
        "axios": "^1.8.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "glob": "^8.1.0",
        "lucide-react": "^0.344.0",
        "node-fetch": "^2.7.0",
        "posthog-js": "^1.304.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-helmet-async": "^2.0.4",
        "react-router-dom": "^6.22.3",
        "tailwind-merge": "^3.0.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.9.1",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^20.17.19",
        "@types/react": "^18.3.5",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.1",
        "autoprefixer": "^10.4.18",
        "chalk": "^5.3.0",
        "eslint": "^9.9.1",
        "eslint-plugin-react-hooks": "^5.1.0-rc.0",
        "eslint-plugin-react-refresh": "^0.4.11",
        "express": "^4.18.3",
        "fs-extra": "^11.3.0",
        "globals": "^15.9.0",
        "jsdom": "^24.0.0",
        "open": "^10.0.3",
        "postcss": "^8.4.35",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.5.3",
        "typescript-eslint": "^8.3.0",
        "vite": "^5.4.2"
    }
}
